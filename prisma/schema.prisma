datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String         @id @default(uuid())
  telegramId   String         @unique
  firstName    String
  username     String?
  isAdmin      Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  subscriptions Subscription[]
  notifications Notification[]
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String
  keyword   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Post {
  id              String         @id // Portal post ID
  title           String
  content         String         // Plain text body
  author          String
  portalCreatedAt DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  attachments     Attachment[]
  notifications   Notification[]
}

model Attachment {
  id                 String   @id @default(uuid())
  portalAttachmentId String   @unique // ID from the portal
  postId             String
  originalFileName   String
  s3Key              String
  mimeType           String
  fileSize           Int
  status             String
  localFilePath      String?  // Path on disk (null if not yet downloaded)
  createdAtPortal    DateTime
  updatedAtPortal    DateTime
  post               Post     @relation(fields: [postId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  status    String   // e.g., SENT, FAILED
  sentAt    DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Config {
  key       String   @id // e.g., SESSION_COOKIE
  value     String
  updatedAt DateTime @updatedAt
}
